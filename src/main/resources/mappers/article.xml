<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.sboard.dao.ArticleDAO">
    <!-- id 값은 DAO의 메서드명으로 맞춰줌

    select 쿼리인 경우  resultType=""를 붙여준다.
    -->
    <select id="select">
    </select>

    <select id="selectAll">
        select
            a.*,
            u.nick
        from article a
        join user u on a.writer = u.userid
        order by a.ano desc
        limit #{pageRequestDTO.start}, 10;
    </select>

    <select id="selectCountAll">
        select count(*) from article;
    </select>

    <insert id="insert">
        insert into article set
            type='free',
            title=#{title},
            content=#{content},
            writer=#{writer},
            regip=#{regip},
            wdate=NOW();

    </insert>

    <update id="update">

    </update>

    <delete id="delete">

    </delete>
</mapper>